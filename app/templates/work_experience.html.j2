{% extends "base.html.j2" %}
{% block title %}CVbot — Work Experience{% endblock %}
{% block body_class %}work-experience-page{% endblock %}

{% block body %}
<div class="container-fluid py-4" style="max-width: 900px;">
    <div class="d-flex align-items-start mb-4">
        <a href="/chat" class="btn btn-sm btn-outline-secondary me-2" data-bs-toggle="tooltip" data-bs-placement="bottom" data-bs-title="Back to interview" aria-label="Back to interview">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h3 class="mb-0"><i class="bi bi-briefcase me-2"></i>{{ page_title }}</h3>
            {% if page_subtitle %}
            <div class="text-body-secondary" style="font-size:0.9rem;"><i class="bi bi-geo-alt"></i> {{ page_subtitle }}</div>
            {% endif %}
        </div>
        <div class="ms-auto d-flex align-items-center gap-2">
            <span class="badge bg-secondary chat-token-badge me-2"><span id="nr-tokens">?</span> tokens</span>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="exportProfileBtn" data-bs-toggle="tooltip" data-bs-placement="bottom" data-bs-title="Export as JSON" aria-label="Export as JSON">
                <i class="bi bi-download"></i>
            </button>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="uploadProfileBtn" data-bs-toggle="tooltip" data-bs-placement="bottom" data-bs-title="Upload JSON" aria-label="Upload JSON">
                <i class="bi bi-upload"></i>
            </button>
            <input type="file" id="uploadProfileInput" accept="application/json,.json" class="d-none">
        </div>
    </div>

    {% if candidates|length > 1 %}
    <div class="card mb-4">
        <div class="card-body">
            <label for="candidateSelect" class="form-label">Candidate</label>
            <select class="form-select" id="candidateSelect" style="max-width: 400px;"
                    onchange="window.location.href='/work-experience?candidate_id=' + this.value">
                {% for c in candidates %}
                <option value="{{ c['id'] }}" {% if c['id'] == candidate_id %}selected{% endif %}>{{ c['display_name'] }}</option>
                {% endfor %}
            </select>
        </div>
    </div>
    {% endif %}

    <!-- Summary & Skills -->
    <div id="summarySection"></div>

    <!-- Work entries -->
    <div id="workSection"></div>

    <!-- Education -->
    <h3 class="mt-5 mb-3"><i class="bi bi-mortarboard me-2"></i>Education</h3>
    <div id="educationSection"></div>

    <!-- Publications -->
    <h3 class="mt-5 mb-3"><i class="bi bi-journal-text me-2"></i>Publications</h3>
    <div id="publicationsSection"></div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="savedToast" class="toast fade align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body"><i class="bi bi-check-lg me-1"></i>Saved</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
    window.__profileData = {{ profile_json | safe }};
    window.__candidateId = {{ candidate_id | tojson }};
</script>
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/dompurify@3.2.6/dist/purify.min.js"></script>
<script src="/static/js/work_experience.js"></script>
{% endblock %}
