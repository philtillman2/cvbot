{% extends "base.html.j2" %}
{% block title %}CVbot — Work Experience{% endblock %}
{% block body_class %}work-experience-page{% endblock %}

{% block body %}
<div class="container-fluid py-4" style="max-width: 900px;">
    <div class="d-flex align-items-center mb-4">
        <a href="/chat" class="btn btn-sm btn-outline-secondary me-3" data-bs-toggle="tooltip" data-bs-placement="bottom" data-bs-title="Back" aria-label="Back">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h3 class="mb-0"><i class="bi bi-briefcase me-2"></i>Work Experience</h3>
        <div class="ms-auto d-flex align-items-center gap-2">
            <button type="button" class="btn btn-sm btn-outline-secondary" id="downloadProfileBtn">
                <i class="bi bi-download me-1"></i>Download JSON
            </button>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="uploadProfileBtn">
                <i class="bi bi-upload me-1"></i>Upload JSON
            </button>
            <input type="file" id="uploadProfileInput" accept="application/json,.json" class="d-none">
        </div>
    </div>

    {% if candidates|length > 1 %}
    <div class="card mb-4">
        <div class="card-body">
            <label for="candidateSelect" class="form-label">Candidate</label>
            <select class="form-select" id="candidateSelect" style="max-width: 400px;"
                    onchange="window.location.href='/work-experience?candidate_id=' + this.value">
                {% for c in candidates %}
                <option value="{{ c['id'] }}" {% if c['id'] == candidate_id %}selected{% endif %}>{{ c['display_name'] }}</option>
                {% endfor %}
            </select>
        </div>
    </div>
    {% endif %}

    <!-- Summary & Skills -->
    <div id="summarySection"></div>

    <!-- Work entries -->
    <div id="workSection"></div>

    <!-- Education -->
    <h3 class="mt-5 mb-3"><i class="bi bi-mortarboard me-2"></i>Education</h3>
    <div id="educationSection"></div>

    <!-- Publications -->
    <h3 class="mt-5 mb-3"><i class="bi bi-journal-text me-2"></i>Publications</h3>
    <div id="publicationsSection"></div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="savedToast" class="toast fade align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body"><i class="bi bi-check-lg me-1"></i>Saved</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
    window.__profileData = {{ profile_json | safe }};
    window.__candidateId = {{ candidate_id | tojson }};
</script>
<script src="/static/js/work_experience.js"></script>
{% endblock %}
